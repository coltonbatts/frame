# Optional: Cloud LLM fallback (OpenRouter, Anthropic, etc.)
# Currently Frame uses only local AI (FFmpeg, whisper.cpp, vision models)
# These are only needed if you add cloud LLM features later

# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: whisper.cpp model override
# WHISPER_MODEL=base

# Optional: Ollama endpoint for local LLM features
# OLLAMA_URL=http://localhost:11434
